.claude/logs/
.claude/projects/

# Secrets / env
.env
.env.local
.env.*.local
*.pem
*.key

# Misc
*.log
*.tmp

# --- Workspace build output (the ONE sanctioned non-submodule directory at root) ---
# Compiled binaries/artifacts from lab tools land in /build/ (namespace per lab,
# e.g. /build/gamepad/...). They are regenerable, so the contents are ignored —
# only /build/README.md is tracked, which keeps the directory present on clone.
/build/*
!/build/README.md
