# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
dist/

# Node (in case any lab adds JS tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.zed/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Local-only Claude state (keep shared config under .claude/ if any)
.claude/settings.local.json
.claude/cache/
.claude/logs/
.claude/projects/

# Generated by claude/hooks/handoff-index.sh on SessionStart — a filename → real-path
# map of every handoff across the labs (their .claude/handoffs/ are git-ignored scratch)
# plus ~/.claude/handoffs/. Derived data, rewritten each session; never tracked. It's a
# root dot-file coordinator (honors the non-dot ⇒ submodule invariant without exception).
/.handoff_index

# Secrets / env
.env
.env.local
.env.*.local
*.pem
*.key

# Misc
*.log
*.tmp

# --- Cross-lab build output (a dot-dir, so it needs NO exception to the
# submodules-only-at-root invariant; the former tracked /build/ was retired). ---
# If a future need collects regenerable lab-tool artifacts at the root, put them
# under /.build/<lab>/ — git-ignored, namespaced per lab. Build systems/sources
# stay inside each lab. (Note: .claude/ is ignored globally via ~/.config/git/ignore.)
/.build/

# Retired-era lab archives (working trees + deployed-artifact snapshots with
# RESTORE.md), e.g. .archive/switchtail-kitty-era/. A dot-dir — honors the
# non-dot => submodule invariant with no exception.
/.archive/
