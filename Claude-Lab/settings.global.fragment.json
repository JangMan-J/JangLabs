{
  "_comment": "Merged into ~/.claude/settings.json by Claude-Lab/install.sh. Existing keys are preserved; arrays are deduped by value; the hooks block adds entries that don't already exist. Permission modes are NEVER touched.",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(cat:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(command -v:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git remote show:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config --get:*)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(uv pip list:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(rm -rf *)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/jangman/.claude/hooks/system-fingerprint.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jangman/.claude/hooks/bash-idiom-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jangman/.claude/hooks/forbidden-files-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/home/jangman/.claude/hooks/config-drift-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jangman/.claude/hooks/syntax-check-touched.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
